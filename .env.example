# WordPress 接続情報（ローカル実行用）
# このファイルをコピーして .env を作り、実際の値を入れてください。
#   cp .env.example .env
# .env は .gitignore 済みなので Git にはコミットされません。

WP_BASE_URL=https://cybernote.click
WP_USERNAME=あなたのWPユーザー名
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# 画像生成などで使う場合のみ
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
